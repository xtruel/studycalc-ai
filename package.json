{
  "name": "studycalc-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:web": "vite build",
    "build:app": "vite build --mode app",
    "preview": "vite preview --port 4173",
    "test": "node --import tsx --test src/lib/*.test.ts",
    "ios:sync": "vite build --mode app && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
