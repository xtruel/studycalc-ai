    "@capacitor/core": "^8.4.0",
    "@capacitor/ios": "^8.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "katex": "^0.17.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/katex": "^0.16.8",
    "@types/node": "^22.14.0",
